{
  "name": "sg",
  "displayName": "SGA",
  "description": "Agent VS Code: Jira -> Copilot (vscode.lm) -> git -> GitHub PR.",
  "version": "0.0.1",
  "publisher": "sg",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "files": [
    "dist/**",
    "package.json",
    "README.md"
  ],
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:sg.implement",
    "onChatParticipant:sg-agent"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sg.implement",
        "title": "SGA: Implement Jira ticket"
      }
    ],
    "configuration": {
      "title": "sg",
      "properties": {
        "sg.jira.url": {
          "type": "string",
          "default": "",
          "description": "Jira base URL (e.g. https://your-company.atlassian.net)"
        },
        "sg.jira.token": {
          "type": "string",
          "default": "",
          "format": "password",
          "description": "Jira API token (PAT). Sent as Bearer."
        },
        "sg.github.url": {
          "type": "string",
          "default": "",
          "description": "GitHub or GitHub Enterprise base URL (e.g. https://github.com or https://ghe.example.com)"
        },
        "sg.github.token": {
          "type": "string",
          "default": "",
          "format": "password",
          "description": "GitHub PAT. Used with token or Bearer auth."
        },
        "sg.git.autoCommit": {
          "type": "boolean",
          "default": true,
          "description": "If false, applies edits only — no branch, commit, push, or PR."
        },
        "sg.git.autoPush": {
          "type": "boolean",
          "default": true,
          "description": "If false, commits locally but does not push or open a PR (ignored when autoCommit is false)."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "sg-agent",
        "name": "SGA",
        "description": "Jira -> Copilot -> GitHub",
        "commands": [
          {
            "name": "implement",
            "description": "Implement a Jira ticket in the current workspace"
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.3",
    "@vscode/vsce": "^3.6.0"
  }
}
